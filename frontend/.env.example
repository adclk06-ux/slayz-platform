# Same-origin REST is recommended so the secure refresh cookie remains first-party.
# Leave NEXT_PUBLIC_API_URL empty and point the Next.js rewrite at the backend.
BACKEND_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_URL=

# For deployments whose frontend host cannot proxy WebSockets (for example,
# some serverless platforms), connect Socket.IO directly to the backend.
NEXT_PUBLIC_WS_URL=http://127.0.0.1:8000
