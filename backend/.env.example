# Application
APP_ENV=development
DEBUG=true
APP_SECRET_KEY=replace-with-a-long-random-secret

# Database (use PostgreSQL in production; SQLite is fine for local development)
DATABASE_URL=sqlite:///./slayz_haber.db
DB_ENCRYPTION_KEY=

# Authentication
JWT_SECRET_KEY=replace-with-a-different-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30
ALLOWED_EMAIL_DOMAIN=slayz.com
COOKIE_SAMESITE=lax

# Frontend / CORS
FRONTEND_BASE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SOCKETIO_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OpenAI (server-side only; never expose this value to the frontend)
OPENAI_API_KEY=
LLM_MODEL=gpt-4o

# News pipeline
SCHEDULER_ENABLED=true
RUN_PIPELINE_ON_STARTUP=true
SCRAPER_INTERVAL_MINUTES=5
SCRAPER_PROXY_LIST=

# Market data: keep false for real-user environments.
MARKET_ALLOW_SIMULATION=false

# E-mail provider: resend | sendgrid | smtp
MAIL_PROVIDER=
MAIL_API_KEY=
MAIL_DEFAULT_FROM=noreply@slayz.com
MAIL_WEBHOOK_SECRET=
RESEARCH_TEAM_EMAILS=

# SMTP settings (used when MAIL_PROVIDER=smtp)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=Slayz Haber Otomasyonu
SMTP_FROM=noreply@slayz.com
